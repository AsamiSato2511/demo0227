<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.ExamSettingMapper">

    <select id="findOne" resultType="ExamSetting">
        SELECT id, exam_date
        FROM exam_settings
        WHERE id = 1
    </select>

    <update id="updateExamDate">
        MERGE INTO exam_settings (id, exam_date)
        KEY (id)
        VALUES (1, #{examDate})
    </update>

</mapper>
